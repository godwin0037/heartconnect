# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5000

# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/heartconnect

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Auth
JWT_SECRET=change-this-to-a-long-random-string
SESSION_SECRET=change-this-too

# Seeded admin account (created on first run if it doesn't exist)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# OAuth (optional - social verification will be disabled if left blank)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
